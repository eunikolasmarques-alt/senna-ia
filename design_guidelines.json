  "instructions_to_main_agent": {
    "general": [
      "Implement the 'Midnight Studio' theme using the provided color palette.",
      "Use 'Plus Jakarta Sans' for all headings to give a modern, geometric feel.",
      "The layout must be responsive. The sidebar should collapse on mobile.",
      "Use 'Recharts' for all charts. Style them with dark backgrounds and neon lines/bars.",
      "Ensure all text has sufficient contrast. Use Zinc-400 for secondary text, not darker."
    ],
    "dashboard": [
      "Create a 'Bento Grid' layout for the main dashboard.",
      "Include 'Financial Overview', 'Active Projects', 'Content Calendar' preview, and 'Team Performance' widgets.",
      "Use the 'Card' component style defined above for all widgets."
    ],
    "kanban": [
      "The Content Grid (Kanban) must have a horizontal scrolling container.",
      "Columns: 'Idea', 'Briefing', 'Production', 'Review', 'Approved', 'Published'.",
      "Cards should show: Title, Client (Badge), Due Date, and Assignee Avatar."
    ],
    "clients": [
      "The Client Profile page must use Tabs for: General, Contracts, Finance, Integrations.",
      "Use a sticky header for the client name and key actions (Edit, Archive)."
    ]
  },
  "universal_guidelines": [
    "Do not use generic centered layouts.",
    "Dark colors look good when used independently without gradients. DO NOT use dark colors as gradients.",
    "Every interaction needs micro-animations - hover states, transitions.",
    "Use 2-3x more spacing than feels comfortable.",
    "Add data-testid to all interactive elements.",
    "Use 'sonner' for toast notifications."
  ]
}