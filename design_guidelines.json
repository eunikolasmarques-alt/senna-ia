{
  "project_name": "AgencyOS - Midnight Studio CRM",
  "design_philosophy": {
    "theme": "Midnight Studio",
    "core_concept": "Productivity meets Creativity. A workspace that feels like a high-end cockpit for digital artists and strategists.",
    "emotional_tone": "Professional, Electric, Focused, Transparent",
    "key_principles": [
      "Dark Mode Default: Reduced eye strain for long work hours.",
      "Data as Art: Charts and metrics should glow and pop like neon signs in the dark.",
      "Glassmorphism: Use subtle glass layers to create depth.",
      "Interactive Feedback: Every click or hover should feel responsive."
    ]
  },
  "typography": {
    "font_family": {
      "heading": "Plus Jakarta Sans, sans-serif",
      "body": "Inter, sans-serif",
      "mono": "JetBrains Mono, monospace"
    },
    "google_fonts_url": "https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap",
    "scaling": {
      "h1": "text-4xl md:text-5xl font-bold tracking-tight",
      "h2": "text-3xl font-semibold tracking-tight",
      "h3": "text-2xl font-semibold tracking-tight",
      "body": "text-base font-normal leading-relaxed text-zinc-400",
      "small": "text-sm font-medium text-zinc-500",
      "label": "text-xs font-semibold uppercase tracking-wider text-zinc-500"
    }
  },
  "colors": {
    "palette": {
      "background": {
        "default": "#09090b",
        "paper": "#18181b",
        "subtle": "#27272a"
      },
      "primary": {
        "default": "#7c3aed",
        "hover": "#6d28d9",
        "foreground": "#ffffff"
      },
      "secondary": {
        "default": "#27272a",
        "hover": "#3f3f46",
        "foreground": "#ffffff"
      },
      "accent": {
        "cyan": "#06b6d4",
        "pink": "#ec4899",
        "green": "#10b981",
        "orange": "#f97316"
      },
      "text": {
        "primary": "#f4f4f5",
        "secondary": "#a1a1aa",
        "muted": "#52525b"
      },
      "border": {
        "default": "#27272a",
        "active": "#52525b"
      }
    },
    "gradients": {
      "primary_glow": "bg-gradient-to-r from-violet-600 to-indigo-600",
      "glass": "bg-zinc-950/70 backdrop-blur-md border border-white/5",
      "card_hover": "hover:bg-zinc-900/80 transition-colors duration-300"
    }
  },
  "layout": {
    "grid_system": "Bento Grid Strategy",
    "spacing": {
      "container_padding": "p-6 md:p-8",
      "card_gap": "gap-6",
      "section_gap": "gap-8"
    },
    "sidebar": {
      "width": "w-64",
      "style": "fixed left-0 top-0 h-full border-r border-zinc-800 bg-zinc-950/95 backdrop-blur-xl z-50",
      "collapsed_width": "w-20"
    },
    "structure": {
      "dashboard": "grid grid-cols-1 md:grid-cols-4 lg:grid-cols-12 gap-6 auto-rows-[minmax(180px,auto)]",
      "page_container": "ml-64 min-h-screen bg-zinc-950 text-zinc-100"
    }
  },
  "components": {
    "Card": {
      "base": "rounded-xl border border-zinc-800 bg-zinc-900/50 shadow-sm",
      "hover": "hover:border-zinc-700 hover:shadow-md transition-all duration-300",
      "header": "p-6 pb-3",
      "content": "p-6 pt-0"
    },
    "Button": {
      "primary": "bg-violet-600 hover:bg-violet-700 text-white shadow-[0_0_15px_rgba(124,58,237,0.3)]",
      "outline": "border border-zinc-700 bg-transparent hover:bg-zinc-800 text-zinc-300",
      "ghost": "hover:bg-zinc-800 text-zinc-400 hover:text-white"
    },
    "Badge": {
      "success": "bg-emerald-500/10 text-emerald-500 border-emerald-500/20",
      "warning": "bg-amber-500/10 text-amber-500 border-amber-500/20",
      "error": "bg-rose-500/10 text-rose-500 border-rose-500/20",
      "info": "bg-blue-500/10 text-blue-500 border-blue-500/20"
    },
    "Input": "bg-zinc-950 border-zinc-800 focus:border-violet-500 focus:ring-violet-500/20 rounded-md",
    "Table": {
      "header": "text-zinc-500 font-medium uppercase text-xs tracking-wider",
      "row": "border-b border-zinc-800 hover:bg-zinc-900/50 transition-colors"
    }
  },
